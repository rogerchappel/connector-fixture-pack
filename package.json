{
  "name": "connector-fixture-pack",
  "version": "0.1.0",
  "description": "Local-first fixture bundles for connector skills and dry-run action plans.",
  "type": "module",
  "bin": {
    "connector-fixture-pack": "./bin/connector-fixture-pack.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check-package.js",
    "smoke": "node bin/connector-fixture-pack.js lint fixtures/crm-basic && node bin/connector-fixture-pack.js render fixtures/crm-basic",
    "build": "node scripts/check-package.js",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skills",
    "connectors",
    "fixtures",
    "dry-run",
    "approval"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-fixture-pack.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-fixture-pack/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-fixture-pack#readme",
  "files": [
    "bin",
    "src",
    "schemas",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
