{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connector Fixture Bundle",
  "type": "object",
  "required": ["name", "version", "connectors"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "connectors": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "generatedBy": { "type": "string" }
  }
}
