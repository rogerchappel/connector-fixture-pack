{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connector Fixture Response",
  "type": "object",
  "required": ["id", "requestId", "status", "body"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "requestId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["dry_run", "mocked", "blocked"] },
    "body": { "type": "object" }
  }
}
